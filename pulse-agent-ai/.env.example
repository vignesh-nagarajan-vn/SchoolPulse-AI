# CPU fallback works without these values.
# Set these when a Lambda GPU server is running Gemma behind an OpenAI-compatible endpoint.
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=google/gemma-4-12B-it
LLM_API_KEY=EMPTY

# Vercel/serverless should use /tmp because the deployed filesystem is read-only.
DATABASE_PATH=/tmp/schoolprint_ai.db
RAG_INDEX_PATH=rag_index/index.joblib
ALLOWED_ORIGINS=*

# Supabase @supabase/server. Copy real values from the Supabase dashboard Connect dialog.
# Never commit real keys.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Optional Google Sheets sync. Prefer service account JSON through an env var.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEET_ID=
