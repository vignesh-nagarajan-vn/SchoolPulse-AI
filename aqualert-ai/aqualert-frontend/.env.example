# ── Vercel KV (Upstash Redis) ────────────────────────────────
# Create a KV database in the Vercel dashboard → Storage → KV,
# then run: vercel env pull .env.local
# These are auto-populated by Vercel when you link the KV database.
#
# If KV_REST_API_URL is absent the app falls back to in-process memory
# (fine for local dev; data is lost on process restart).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Auth ─────────────────────────────────────────────────────
# Must match INGEST_SECRET in scripts/.env on the device.
# Leave blank to disable auth (not recommended for production).
INGEST_SECRET=

# ── Alert thresholds (cm) ────────────────────────────────────
# Distance at which the sensor triggers a LEAK DETECTED alert.
NEXT_PUBLIC_ALERT_THRESHOLD=10
# Distance at which a WARNING is shown.
NEXT_PUBLIC_WARN_THRESHOLD=20
