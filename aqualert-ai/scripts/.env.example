# Copy this to scripts/.env and fill in your values.
# Never commit .env to git.

# ── Required ────────────────────────────────────────────────
# The full URL of your Vercel deployment's ingest endpoint.
# Example: https://your-project.vercel.app/api/ingest
VERCEL_INGEST_URL=

# Shared secret — must match INGEST_SECRET in Vercel env vars.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
INGEST_SECRET=

# ── Optional ────────────────────────────────────────────────
# Serial port — leave blank for auto-detect.
# Windows: COM3, COM4 …   Linux/Mac: /dev/ttyUSB0, /dev/ttyACM0 …
SERIAL_PORT=

# Arduino baud rate (must match your Arduino sketch).
# The current UNO sketch emits JSON over Serial at 115200 baud.
BAUD_RATE=115200

# Logical name for this sensor node — shown on the dashboard.
DEVICE_ID=aqualert-1

# How often (in seconds) to push readings to Vercel.
# Arduino may output faster; this throttles network calls.
PUSH_INTERVAL=1.0
